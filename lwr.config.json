{
    "lwc": {
        "modules": [
            {
                "dir": "$rootDir/src/modules"
            }
        ]
    },
    "routes": [
        {
            "id": "example",
            "path": "/",
            "rootComponent": "example/app"
        }
    ],
    "assets": [
        {
            "alias": "assetsDir",
            "dir": "$rootDir/src/assets",
            "urlPath": "/public/assets"
        },
        {
            "alias": "sldsAssetsDir",
            "dir": "$rootDir/src/assets/slds",
            "urlPath": "/slds"
        },
        {
            "alias": "favicon",
            "file": "$rootDir/src/assets/favicon.ico",
            "urlPath": "/favicon.ico"
        }
    ]
}