{
  "name": "lwr-project",
  "version": "0.0.1",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rimraf node_modules __lwr_cache__ site",
    "copy:slds": "node scripts/copy-assets.mjs",
    "predev": "npm run copy:slds",
    "prebuild": "npm run copy:slds",
    "dev": "lwr dev",
    "dev:compat": "lwr dev --mode compat",
    "build": "lwr build --clean",
    "build:prod-compat": "lwr build --clean --mode prod-compat",
    "start": "lwr start",
    "stage": "yarn build && yarn start",
    "stage:prod-compat": "yarn build:prod-compat && yarn start",
    "test": "jest"
  },
  "dependencies": {
    "lwc": "latest",
    "lwr": "^0.20.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "volta": {
    "node": "20.16.0"
  },
  "overrides": {
    "@lwrjs/o11y": {
      "protobufjs": "^7.5.0"
    },
    "braces": "^3.0.3",
    "micromatch": "^4.0.8",
    "anymatch": "^3.1.3",
    "postcss": "^8.4.31",
    "on-headers": "^1.1.0"
  },
  "devDependencies": {
    "@lwc/synthetic-shadow": "^8.22.6",
    "@salesforce-ux/design-system": "^2.28.0",
    "cpx": "^1.5.0",
    "jest": "^30.2.0"
  }
}